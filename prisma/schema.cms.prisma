generator cms {
  provider = "prisma-client-js"
  output   = "../src/generated/cms-client"
}

datasource db {
  provider = "postgresql"
  url      = env("CMS_DATABASE_URL")
}

// ============================================================
// CMS v2 tables — READ-ONLY
// Mapped to the actual tables present in the local cms_v2 DB.
// ============================================================

model CmsPatient {
  id          BigInt    @id @map("id")
  code        String?   @unique @map("code") @db.VarChar(30)
  fullName    String?   @map("fullname") @db.VarChar(200)
  lastName    String?   @map("lastname") @db.VarChar(80)
  firstName   String?   @map("firstname") @db.VarChar(150)
  middleName  String?   @map("middlename") @db.VarChar(80)
  gender      String?   @map("gender") @db.VarChar(10)
  dob         DateTime  @map("dob") @db.Date
  email       String?   @map("email") @db.VarChar(5000)
  mobile      String?   @map("moblie") @db.VarChar(255)
  contactNo   String?   @map("contactno") @db.VarChar(80)
  fullAddress String?   @map("fulladdress") @db.VarChar(500)
  isActive        Int       @map("isactive")
  pictureLink     String?   @map("picturelink") @db.VarChar(100)
  lastVisit       DateTime? @map("lastvisit") @db.Date
  uploaddatetime  DateTime  @db.Timestamp(6)

  queues CmsQueue[]

  @@map("patient")
}

model CmsQueue {
  id           BigInt    @id @default(autoincrement()) @map("id")
  idbu         String?   @map("idbu") @db.VarChar(10)
  code         String?   @map("code") @db.VarChar(20)
  date         DateTime  @map("date") @db.Date
  dateTime     DateTime  @map("datetime") @db.Timestamp(6)
  idPatient    BigInt    @map("idpatient")
  qFullName    String?   @map("qfullname") @db.VarChar(200)
  qFirstName   String?   @map("qfirstname") @db.VarChar(150)
  qLastName    String?   @map("qlastname") @db.VarChar(80)
  qGender      String?   @map("qgender") @db.VarChar(10)
  qDob         DateTime? @map("qdob") @db.Date
  agePatient   Int?      @map("agepatient")
  status       Int       @map("status") @db.SmallInt
  accessionNo  String?   @map("accessionno") @db.VarChar(50)
  patientType  String?   @map("patienttype") @db.VarChar(80)
  inputBy      String?   @map("inputby") @db.VarChar(30)
  notes        String?   @map("notes")
  cancelReason String?   @map("cancelreason") @db.VarChar(2000)

  patient      CmsPatient       @relation(fields: [idPatient], references: [id])
  transactions CmsTransaction[]

  @@map("queue")
}

model CmsTransaction {
  id                   BigInt   @id @default(autoincrement()) @map("id")
  idQueue              BigInt   @map("idqueue")
  date                 DateTime @map("date") @db.Date
  nameDoctor           String?  @map("namedoctor") @db.VarChar(200)
  nameCompany          String?  @map("namecompany") @db.VarChar(500)
  transactionType      String?  @map("transactiontype") @db.VarChar(150)
  codeItemPrice        String?  @map("codeitemprice") @db.VarChar(30)
  descriptionItemPrice String?  @map("descriptionitemprice") @db.VarChar(500)
  amountItemPrice      Decimal? @map("amountitemprice") @db.Decimal(10, 2)
  groupItemMaster      String?  @map("groupitemmaster") @db.VarChar(50)
  status               Int      @map("status") @db.SmallInt

  queue CmsQueue @relation(fields: [idQueue], references: [id])

  @@map("transactions")
}

// vitalsign — mapped to actual CMS DB columns
model CmsVitalSign {
  id               BigInt   @id @map("id")
  idQueue          BigInt   @map("idqueue")
  queueCode        String?  @map("queuecode") @db.VarChar(50)
  pcpId            BigInt?  @map("pcpid")
  pcpName          String?  @map("pcpname") @db.VarChar(200)
  chiefComplaint   String?  @map("chiefcomplaint") @db.VarChar(500)
  pulseRate        String?  @map("pulserate") @db.VarChar(50)
  respiratoryRate  String?  @map("respiratoryrate") @db.VarChar(50)
  bpSystolic       Int?     @map("bloodpresure")
  bpDiastolic      Int?     @map("bloodpresureover")
  bpSystolic2      Int?     @map("bloodpresure2")
  bpDiastolic2     Int?     @map("bloodpresureover2")
  bpSystolic3      Int?     @map("bloodpresure3")
  bpDiastolic3     Int?     @map("bloodpresureover3")
  temperature      String?  @map("temperature") @db.VarChar(50)
  height           String?  @map("height") @db.VarChar(50)
  weight           String?  @map("weight") @db.VarChar(50)
  bmi              String?  @map("bmi") @db.VarChar(50)
  bmiCategory      String?  @map("bmicategory") @db.VarChar(50)
  inputBy          String?  @map("inputby") @db.VarChar(50)
  inputDate        DateTime? @map("inputdate")
  updateBy         String?  @map("updateby") @db.VarChar(50)
  updatedDate      DateTime? @map("updateddate")

  @@map("vitalsign")
}

model CmsCompany {
  id          Int     @id @map("id")
  code        String? @map("code") @db.VarChar(50)
  name        String? @map("name") @db.VarChar(500)
  shortName   String? @map("shortname") @db.VarChar(80)
  group       String? @map("group") @db.VarChar(80)
  billingType String? @map("billingtype") @db.VarChar(80)
  address     String? @map("address") @db.VarChar(500)
  email       String? @map("email") @db.VarChar(300)
  status      String? @map("status") @db.VarChar(10)
  startDate   DateTime? @map("startdate") @db.Date
  endDate     DateTime? @map("enddate") @db.Date
  empId       String? @map("empid") @db.VarChar(15)

  @@map("company")
}
