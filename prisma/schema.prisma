generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Portal Users - patient and HR staff accounts
model PortalUser {
  id               String    @id @default(cuid())
  patientCode      String?   @unique @map("patient_code")
  hrCode           String?   @unique @map("hr_code")
  pin              String?   @map("pin") @db.VarChar(3)
  firstName        String    @map("first_name")
  lastName         String    @map("last_name")
  email            String    @unique
  mobile           String    @unique
  password         String
  dob              DateTime  @db.Date
  role             UserRole  @default(PATIENT)
  isVerified       Boolean   @default(false) @map("is_verified")
  isActive         Boolean   @default(true) @map("is_active")
  emailVerifiedAt  DateTime? @map("email_verified_at")
  mobileVerifiedAt DateTime? @map("mobile_verified_at")
  lastLoginAt      DateTime? @map("last_login_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")

  otps             PortalOtp[]
  resultAccessLogs PortalResultAccessLog[]
  shareLinks       PortalShareLink[]
  appointments     PortalAppointment[]
  notifications    PortalNotification[]
  sessions         PortalSession[]

  @@map("portal_users")
}

// OTP for verification and password reset
model PortalOtp {
  id        String     @id @default(cuid())
  userId    String     @map("user_id")
  type      OtpType
  code      String     @db.VarChar(10)
  purpose   OtpPurpose
  expiresAt DateTime   @map("expires_at")
  usedAt    DateTime?  @map("used_at")
  createdAt DateTime   @default(now()) @map("created_at")

  user PortalUser @relation(fields: [userId], references: [id])

  @@map("portal_otp")
}

// Audit trail for result access
model PortalResultAccessLog {
  id           String     @id @default(cuid())
  portalUserId String     @map("portal_user_id")
  queueCode    String     @map("queue_code")
  accessType   AccessType @map("access_type")
  filePath     String?    @map("file_path") @db.VarChar(500)
  accessedAt   DateTime   @default(now()) @map("accessed_at")
  ipAddress    String?    @map("ip_address") @db.VarChar(45)

  user PortalUser @relation(fields: [portalUserId], references: [id])

  @@map("portal_result_access_log")
}

// Appointment bookings (portal-side scheduling)
model PortalAppointment {
  id              String    @id @default(cuid())
  userId          String    @map("user_id")
  appointmentDate DateTime  @map("appointment_date")
  packageType     String    @map("package_type") @db.VarChar(100)
  branch          String    @db.VarChar(100)
  notes           String?   @db.Text
  status          String    @default("confirmed") @db.VarChar(20) // confirmed | cancelled | completed
  createdAt       DateTime  @default(now()) @map("created_at")

  user PortalUser @relation(fields: [userId], references: [id])

  @@map("portal_appointments")
}

// Secure share links for lab results
model PortalShareLink {
  id          String    @id @default(cuid())
  userId      String    @map("user_id")
  queueCode   String    @map("queue_code")
  resultLabel String?   @map("result_label") @db.VarChar(200)
  token       String    @unique
  recipient   String?   @db.VarChar(200)
  expiresAt   DateTime  @map("expires_at")
  revokedAt   DateTime? @map("revoked_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  viewCount   Int       @default(0) @map("view_count")

  user PortalUser @relation(fields: [userId], references: [id])

  @@map("portal_share_links")
}

// In-app notifications for patients
model PortalNotification {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  title     String
  message   String    @db.Text
  type      String    @default("info")
  isRead    Boolean   @default(false) @map("is_read")
  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user PortalUser @relation(fields: [userId], references: [id])

  @@map("portal_notifications")
}

// Sessions for NextAuth
model PortalSession {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  sessionToken String   @unique @map("session_token")
  expires      DateTime

  user PortalUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("portal_sessions")
}

// Verification tokens for email/magic link
model PortalVerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("portal_verification_tokens")
}

enum UserRole {
  PATIENT
  HR
  ADMIN

  @@map("user_role")
}

model PortalEmployeeDepartment {
  id          String   @id @default(cuid())
  patientCode String   @unique @map("patient_code") @db.VarChar(50)
  department  String   @db.VarChar(200)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([department])
  @@map("portal_employee_department")
}

model PortalAuditLog {
  id          String   @id @default(cuid())
  hrUserId    String   @map("hr_user_id")
  hrUserName  String   @map("hr_user_name") @db.VarChar(200)
  action      String   @db.VarChar(50)
  detail      String   @db.Text
  targetCode  String?  @map("target_code") @db.VarChar(50)
  ipAddress   String?  @map("ip_address") @db.VarChar(45)
  userAgent   String?  @map("user_agent") @db.VarChar(500)
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([action])
  @@index([hrUserId])
  @@index([createdAt])
  @@map("portal_audit_log")
}

enum UatSeverity {
  Bug
  Suggestion
  Question
  Blocker

  @@map("uat_severity")
}

enum UatStatus {
  Open
  Acknowledged
  Resolved

  @@map("uat_status")
}

model UatFeedback {
  id             BigInt      @id @default(autoincrement())
  submittedBy    String      @map("submitted_by") @db.VarChar(100)
  userFullname   String?     @map("user_fullname") @db.VarChar(200)
  userRole       String      @map("user_role") @db.VarChar(100)
  module         String      @db.VarChar(100)
  pageUrl        String      @map("page_url") @db.Text
  pageTitle      String?     @map("page_title") @db.VarChar(200)
  severity       UatSeverity
  description    String      @db.Text
  screenshotPath String?     @map("screenshot_path") @db.Text
  status         UatStatus   @default(Open)
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  @@map("uat_feedback")
}

model UatSettings {
  id          Int       @id @default(1)
  isActive    Boolean   @default(false) @map("is_active")
  activeFrom  DateTime? @map("active_from") @db.Date
  activeUntil DateTime? @map("active_until") @db.Date
  updatedBy   String?   @map("updated_by") @db.VarChar(100)
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@map("uat_settings")
}

enum OtpType {
  EMAIL
  MOBILE

  @@map("otp_type")
}

enum OtpPurpose {
  REGISTER
  LOGIN
  RESET

  @@map("otp_purpose")
}

enum AccessType {
  LAB_PDF @map("lab_pdf")
  VITALS
  RECEIPT
  SUMMARY

  @@map("access_type")
}

// ============================================================
// CMS v2 tables — READ-ONLY, mapped to actual cms_v2 tables.
// These are NOT managed by portal migrations.
// ============================================================

model CmsPatient {
  id          BigInt    @id @map("id")
  code        String?   @unique @map("code") @db.VarChar(30)
  fullName    String?   @map("fullname") @db.VarChar(200)
  lastName    String?   @map("lastname") @db.VarChar(80)
  firstName   String?   @map("firstname") @db.VarChar(150)
  middleName  String?   @map("middlename") @db.VarChar(80)
  gender      String?   @map("gender") @db.VarChar(10)
  dob         DateTime  @map("dob") @db.Date
  email       String?   @map("email") @db.VarChar(5000)
  mobile      String?   @map("moblie") @db.VarChar(255)
  contactNo   String?   @map("contactno") @db.VarChar(80)
  fullAddress String?   @map("fulladdress") @db.VarChar(500)
  isActive        Int       @map("isactive")
  pictureLink     String?   @map("picturelink") @db.VarChar(100)
  lastVisit       DateTime? @map("lastvisit") @db.Date
  uploaddatetime  DateTime  @db.Timestamp(6)

  queues CmsQueue[]

  @@map("patient")
}

model CmsQueue {
  id           BigInt    @id @default(autoincrement()) @map("id")
  idbu         String?   @map("idbu") @db.VarChar(10)
  code         String?   @map("code") @db.VarChar(20)
  date         DateTime  @map("Date") @db.Date
  dateTime     DateTime  @map("datetime") @db.Timestamp(6)
  idPatient    BigInt    @map("idpatient")
  qFullName    String?   @map("qfullname") @db.VarChar(200)
  qFirstName   String?   @map("qfirstname") @db.VarChar(150)
  qLastName    String?   @map("qlastname") @db.VarChar(80)
  qGender      String?   @map("qgender") @db.VarChar(10)
  qDob         DateTime? @map("qdob") @db.Date
  agePatient   Int?      @map("agepatient")
  status       Int       @map("status") @db.SmallInt
  accessionNo  String?   @map("accessionno") @db.VarChar(50)
  patientType  String?   @map("patienttype") @db.VarChar(80)
  inputBy      String?   @map("inputby") @db.VarChar(30)
  notes        String?   @map("notes")
  cancelReason String?   @map("cancelreason") @db.VarChar(2000)

  patient      CmsPatient       @relation(fields: [idPatient], references: [id])
  transactions CmsTransaction[]

  @@map("queue")
}

model CmsTransaction {
  id                   BigInt   @id @default(autoincrement()) @map("id")
  idQueue              BigInt   @map("idqueue")
  date                 DateTime @map("Date") @db.Date
  nameDoctor           String?  @map("namedoctor") @db.VarChar(200)
  nameCompany          String?  @map("namecompany") @db.VarChar(500)
  transactionType      String?  @map("transactiontype") @db.VarChar(150)
  codeItemPrice        String?  @map("codeitemprice") @db.VarChar(30)
  descriptionItemPrice String?  @map("descriptionitemprice") @db.VarChar(500)
  amountItemPrice      Decimal? @map("amountitemprice") @db.Decimal(10, 2)
  groupItemMaster      String?  @map("groupitemmaster") @db.VarChar(50)
  status               Int      @map("status") @db.SmallInt

  queue CmsQueue @relation(fields: [idQueue], references: [id])

  @@map("transactions")
}

// vitalsign — queue_id is integer in this db; standalone (no FK)
model CmsVitalSign {
  id              Int      @id @default(autoincrement())
  queueId         Int      @unique @map("queue_id")
  patientId       String?  @map("patient_id") @db.VarChar(50)
  chiefComplaint  String?  @map("chief_complaint")
  pcpDoctor       String?  @map("pcp_doctor") @db.VarChar(200)
  bpSystolic      Int?     @map("bp_systolic")
  bpDiastolic     Int?     @map("bp_diastolic")
  heartRate       Int?     @map("heart_rate")
  temperature     Float?   @map("temperature")
  respiratoryRate Int?     @map("respiratory_rate")
  weightKg        Float?   @map("weight_kg")
  heightCm        Float?   @map("height_cm")
  bmi             Float?   @map("bmi")
  recordedBy      Int?     @map("recorded_by")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("vitalsign")
}

model CmsCompany {
  id          Int       @id @map("id")
  code        String?   @map("code") @db.VarChar(50)
  name        String?   @map("name") @db.VarChar(500)
  shortName   String?   @map("shortname") @db.VarChar(80)
  group       String?   @map("group") @db.VarChar(80)
  billingType String?   @map("billingtype") @db.VarChar(80)
  address     String?   @map("address") @db.VarChar(500)
  email       String?   @map("email") @db.VarChar(300)
  status      String?   @map("status") @db.VarChar(10)
  startDate   DateTime? @map("startdate") @db.Date
  endDate     DateTime? @map("enddate") @db.Date
  empId       String?   @map("empid") @db.VarChar(15)

  @@map("company")
}
