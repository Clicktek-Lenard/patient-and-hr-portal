# ─── Portal Database (Prisma) ───────────────────────────────────────────────
# PostgreSQL connection string for the patient portal database
DATABASE_URL="postgresql://user:password@host:5432/portal_db?schema=public"

# ─── CMS Database (read-only, Prisma) ───────────────────────────────────────
# PostgreSQL connection string for the CMS/CMSv2 read-only database
CMS_DATABASE_URL="postgresql://user:password@host:5432/cms_db?schema=public"

# ─── NextAuth / Auth.js ──────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-here"

# ─── Optional ────────────────────────────────────────────────────────────────
# Local directory for PDF files (leave empty on Vercel — use S3/cloud storage)
# CMS_PDF_LOCAL_DIR="/path/to/pdfs"
